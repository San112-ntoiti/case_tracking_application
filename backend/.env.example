# ─── Kenya Court Case Tracker — Environment Variables ────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ─── Django Core ─────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_NAME=court_tracker
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ─── Redis (Celery broker) ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── M-Pesa Daraja API ───────────────────────────────────────────────────────
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_daraja_passkey
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/v1/billing/mpesa/callback/

# ─── Email (SendGrid) ────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
SENDGRID_API_KEY=your_sendgrid_api_key
DEFAULT_FROM_EMAIL=noreply@courttracker.co.ke

# ─── Africa's Talking (SMS) ──────────────────────────────────────────────────
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_at_api_key
AFRICASTALKING_SENDER_ID=CourtTrack

# ─── Twilio (WhatsApp) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
